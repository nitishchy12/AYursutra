PORT=5000
MONGODB_URI=mongodb://localhost:27017/ayursutra
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Email Configuration. For Gmail, use a 16-character app password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
# Optional email tuning. Set EMAIL_ENABLED=false to use only in-app notifications.
# EMAIL_ENABLED=true
# EMAIL_DNS_SERVERS=8.8.8.8,1.1.1.1

# SMS reminders through Twilio. Set SMS_ENABLED=false to use only in-app reminders.
# SMS_ENABLED=true
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_PHONE=+1234567890
